# GitHub Actions Secrets Template
# Copy this file to .secrets and fill in the values to test workflows locally with 'act'.
# DO NOT COMMIT THE .SECRETS FILE.

# Android Signing
ANDROID_KEYSTORE_BASE64=your_base64_encoded_keystore
ANDROID_KEYSTORE_PASSWORD=your_password
ANDROID_KEY_ALIAS=upload
ANDROID_KEY_PASSWORD=your_password

# Firebase
FIREBASE_ANDROID_APP_ID=your_app_id
FIREBASE_SERVICE_ACCOUNT_KEY=your_firebase_sa_json_content
FIREBASE_SERVICE_ACCOUNT_ROOMBOOKER_5E947=your_firebase_sa_json_content

# Google Play
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=your_play_sa_json_content_or_base64

# Monitoring
SENTRY_AUTH_TOKEN=your_sentry_token
