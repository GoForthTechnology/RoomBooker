rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(orgID) {
      return get(/databases/$(database)/documents/orgs/$(orgID)).data.ownerID == request.auth.uid;
    }

    function incomingData() {
      return request.resource.data;
    }
    
    function hasAll(fields) {
      return incomingData().keys().hasAll(fields);
    }
    
    function isNotEmptyString(field) {
      return incomingData()[field] is string && incomingData()[field].size() > 0;
    }

    // --- Rules ---

    match /users/{userID} {
      allow read, write: if request.auth.uid == userID;
    }
    
    match /orgs/{orgID} {
      function isAdmin() {
        return isOwner(orgID) || exists(/databases/$(database)/documents/orgs/$(orgID)/active-admins/$(request.auth.uid));
      }

      function isAuthorizedKiosk(roomID) {
        return request.auth != null
          && exists(/databases/$(database)/documents/orgs/$(orgID)/rooms/$(roomID)/kiosk-grants/$(request.auth.uid));
      }

      allow read: if true; 
      allow create: if isAuthenticated() 
                    && incomingData().ownerID == request.auth.uid
                    && hasAll(['name', 'ownerID', 'acceptingAdminRequests'])
                    && isNotEmptyString('name');
                    
      allow write: if isAdmin();
      
      match /admin-requests/{userID} {
        allow create: if request.auth.uid == userID;
        allow read: if request.auth.uid == userID || isAdmin();
        allow write: if isAdmin();
      }
      
      match /active-admins/{userID} {
        allow read: if request.auth.uid == userID || isAdmin();
        allow create: if isAdmin()
          || (request.auth.uid == userID
              && request.auth.token.email_verified == true
              && exists(/databases/$(database)/documents/orgs/$(orgID)/pending-invites/$(request.auth.token.email.lower())));
        allow update, delete: if isAdmin();
      }

      match /pending-invites/{email} {
        allow read: if request.auth.token.email.lower() == email || isAdmin();
        allow create: if isAdmin();
        allow delete: if isAdmin() || request.auth.token.email.lower() == email;
      }
      
      match /pending-requests/{requestID} {
        allow create: if true; 
        allow read: if true;
        allow write: if isAdmin();
      } 
     
      match /request-details/{requestID} {
        allow create: if true;
        allow read: if isAdmin()
          || isAuthorizedKiosk(get(/databases/$(database)/documents/orgs/$(orgID)/confirmed-requests/$(requestID)).data.roomID);
        allow write: if isAdmin();
      }

      match /denied-requests/{requestID} {
        allow read, write: if isAdmin();
      }

      match /amendment-details/{requestID} {
        allow create: if true;
        allow read, update, delete: if isAdmin();
      }

      match /confirmed-requests/{requestID} {
        allow read: if true;
        allow create: if isAdmin() || isAuthorizedKiosk(incomingData().roomID);
        allow update: if isAdmin()
          || (request.resource.data.diff(resource.data)
                  .affectedKeys().hasOnly(['hasPendingAmendment'])
              && request.resource.data.hasPendingAmendment == true
              && resource.data.get('hasPendingAmendment', false) == false);
        allow delete: if isAdmin();
      }

      match /rooms/{roomID} {
        allow read: if true;
        allow write: if isAdmin();

        match /kiosk-grants/{uid} {
          allow read: if isAdmin();
          allow write: if false; // Only the Admin SDK (Cloud Functions) writes grants
        }

        match /provisioning-errors/{docID} {
          allow read, delete: if isAuthorizedKiosk(roomID);
          allow create, update: if false; // Only the Admin SDK (Cloud Functions) writes errors
        }
      }

      match /request-logs/{logID} {
        allow read, write: if isAdmin();
        allow create: if isAdmin()
          || isAuthorizedKiosk(get(/databases/$(database)/documents/orgs/$(orgID)/confirmed-requests/$(incomingData().requestID)).data.roomID);
      }
    }

    // CollectionGroup rule for pending-invites claim lookup
    match /{path=**}/pending-invites/{email} {
      allow read: if isAuthenticated()
        && resource.data.email == request.auth.token.email.lower();
    }

    // Provisioning Handshake Rules
    match /provisioning_codes/{code} {
      // Allow the Kiosk to "get" the code without auth to start the handshake
      allow get: if true;
      // Allow authenticated admins/users to create a code
      allow create: if isAuthenticated();
      // Allow anyone to delete the code once consumed (handshake logic)
      allow delete: if true;
    }
  }
}
